# Entorno virtual
venv/
env/
.env

# Datos crudos y procesados (demasiado pesados para GitHub)
data/raw/
data/processed/*.csv
data/features/

# EXCEPCIONES: archivos procesados pequeños que sí queremos versionar
!data/processed/semana3_metricas_resumen.csv
!data/processed/.gitkeep
!data/raw/.gitkeep
!data/raw/fjelstul/.gitkeep

# Modelos entrenados (.pkl pueden pesar mucho)
models/*.pkl
models/*.npy

# EXCEPCIONES: archivos de configuración/métricas que sí versionamos
!models/*.json
!models/.gitkeep

